  "files": [
    "bin/**/*.d.ts",
    "bin/**/*.js",
    "bin/**/*.js.map",
    "lib/**/*.d.ts",
    "lib/**/*.js",
    "lib/**/*.js.map"
  ],
  "scripts": {
    "build": "yarn run build:ts",
    "build:ts": "node \"../../node_modules/typescript/bin/tsc\""
  },
  "dependencies": {
    "@comunica/query-sparql-hdt": "^5.1.3",
    "@comunica/utils-mcp": "^5.1.3"
  }
